<p style="color: green"><%= notice %></p>

<%= render @product %>

<div>
  <%= button_to "Edit this product", edit_product_path(@product), method: :get, data: {turbo_confirm: "are you sure? "}%>
  <%= button_to "Back to products (Button)", products_path, method: :get  %>
  <%= link_to "Back to products (Link)", products_path %>
  <%= button_to "Destroy this product", @product, method: :delete, data: {confirm: "are you sure? "}%>
</div>
